# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini AI (optional - used by /analyze endpoint)
GEMINI_API_KEY=

# Redis (optional - required for background jobs + caching)
# e.g. redis://localhost:6379 or rediss://user:pass@host:port
REDIS_URL=

# Email (optional - required for weekly digest emails)
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev

# CORS (e.g., https://dsaflow-dashboard.vercel.app)
ALLOWED_ORIGINS=

# Public URLs
API_BASE_URL=
DASHBOARD_URL=
NEXT_PUBLIC_SITE_URL=

# Server
NODE_ENV=development
PORT=3001
